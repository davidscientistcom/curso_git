{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Pytest: Current File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-sv" 
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}